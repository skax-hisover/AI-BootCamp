AOAI_ENDPOINT=https://your-azure-openai-endpoint.openai.azure.com/
AOAI_API_KEY=your_azure_openai_api_key
AOAI_DEPLOY_GPT4O=gpt-4o
AOAI_DEPLOY_EMBED_ADA=text-embedding-ada-002
AOAI_API_VERSION=2024-10-21

# Optional memory guard settings for multi-user/runtime safety
MEMORY_MAX_SESSIONS=200
MEMORY_TTL_SECONDS=86400

# Final answer cache controls (preferred keys)
FINAL_ANSWER_CACHE_ENABLED=true
FINAL_ANSWER_CACHE_BYPASS_CONTEXTUAL=true
FINAL_ANSWER_CACHE_MAX_PER_SESSION=5

# Legacy-compatible aliases (optional; FINAL_ANSWER_CACHE_* takes precedence)
# GRAPH_STATE_CACHE_ENABLED=true
# GRAPH_STATE_CACHE_BYPASS_CONTEXTUAL=true
# GRAPH_STATE_CACHE_MAX_PER_SESSION=5
